<!DOCTYPE html>
<html>
<head>
<title>Items</title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<h1>Item List</h1>

<form action="/add" method="POST">

<input name="name" placeholder="name">
<input name="description" placeholder="description">

<button type="submit">Add</button>

</form>

<ul>

<% items.forEach(item => { %>

<li>
<b><%= item.name %></b>
<%= item.description %>
</li>

<% }) %>

</ul>

</body>
</html>
